{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@logue/reverb",
  "version": "1.6.0",
  "description": "JavaScript Reverb effect class",
  "keywords": [
    "webaudio",
    "convolver",
    "effect",
    "reverb"
  ],
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "Logue",
    "email": "logue@hotmail.co.jp",
    "url": "https://logue.dev/"
  },
  "homepage": "https://github.com/logue/Reverb.js",
  "repository": {
    "type": "git",
    "url": "git@github.com:logue/Reverb.js.git"
  },
  "bugs": {
    "url": "https://github.com/logue/Reverb.js/issues"
  },
  "files": [
    "dist"
  ],
  "main": "dist/Reverb.umd.js",
  "module": "dist/Reverb.es.js",
  "browser": "dist/Reverb.umd.js",
  "types": "dist/Reverb.d.ts",
  "exports": {
    ".": {
      "import": "./dist/Reverb.es.js",
      "types": "./dist/Reverb.d.ts",
      "require": "./dist/Reverb.umd.js",
      "default": "./dist/Reverb.es.js"
    },
    "./umd": {
      "default": "./dist/Reverb.umd.js"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "packageManager": "pnpm@11.5.2",
  "sideEffects": false,
  "scripts": {
    "build": "rslib",
    "build:docs": "rsbuild build",
    "check": "biome check --write",
    "dev": "rslib --watch",
    "dev:docs": "rsbuild",
    "preview": "rsbuild preview",
    "format": "prettier --write .",
    "lint": "rslint",
    "test": "rstest",
    "test:watch": "rstest --watch",
    "version": "auto-changelog -p && git add CHANGELOG.md",
    "prepare": "husky install"
  },
  "peerDependencies": {
    "@thi.ng/colored-noise": "^1",
    "@thi.ng/random": "^4",
    "@thi.ng/transducers": "^9.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@rsbuild/core": "^2.0.11",
    "@rslib/core": "^0.22.0",
    "@rslint/core": "^0.5.3",
    "@rstest/adapter-rslib": "^0.10.3",
    "@rstest/core": "^0.10.3",
    "@tsconfig/node-lts": "^24.0.0",
    "@types/node": "^25.9.1",
    "@types/three": "^0.184.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "three": "^0.184.0",
    "typescript": "^6.0.3"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,ts,json,htm,html,md}": "pnpm run format",
    "*": "prettier -w -u"
  }
}
