{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@logue/reverb",
  "version": "1.6.1",
  "description": "JavaScript Reverb effect class",
  "keywords": [
    "webaudio",
    "convolver",
    "effect",
    "reverb"
  ],
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "Logue",
    "email": "logue@hotmail.co.jp",
    "url": "https://logue.dev/"
  },
  "homepage": "https://github.com/logue/Reverb.js",
  "repository": {
    "type": "git",
    "url": "git@github.com:logue/Reverb.js.git"
  },
  "bugs": {
    "url": "https://github.com/logue/Reverb.js/issues"
  },
  "files": [
    "dist"
  ],
  "main": "dist/Reverb.umd.js",
  "module": "dist/Reverb.es.js",
  "browser": "dist/Reverb.umd.js",
  "types": "dist/Reverb.d.ts",
  "exports": {
    ".": {
      "import": "./dist/Reverb.es.js",
      "types": "./dist/Reverb.d.ts",
      "require": "./dist/Reverb.umd.js",
      "default": "./dist/Reverb.es.js"
    },
    "./umd": {
      "default": "./dist/Reverb.umd.js"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "packageManager": "pnpm@11.16.0",
  "sideEffects": false,
  "scripts": {
    "dev": "rslib --watch",
    "dev:docs": "rsbuild",
    "preview": "rsbuild preview",
    "lint": "run-s lint:*",
    "lint:rslint": "rslint .",
    "lint:biome": "biome check --write",
    "build": "rslib build",
    "build:docs": "rsbuild build",
    "test": "rstest",
    "test:watch": "rstest --watch",
    "version": "auto-changelog -p && git add CHANGELOG.md",
    "prepare": "husky install"
  },
  "peerDependencies": {
    "@thi.ng/colored-noise": "^1",
    "@thi.ng/random": "^4",
    "@thi.ng/transducers": "^9.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@microsoft/api-extractor": "^7.58.12",
    "@rsbuild/core": "^2.1.7",
    "@rslib/core": "^0.23.2",
    "@rslint/core": "^0.7.0",
    "@rstest/adapter-rslib": "^0.11.3",
    "@rstest/core": "^0.11.3",
    "@tsconfig/node-lts": "^24.0.0",
    "@types/node": "^26.1.1",
    "@types/three": "^0.185.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.1",
    "npm-run-all2": "^9.0.2",
    "three": "^0.185.1",
    "typescript": "^7.0.2"
  },
  "lint-staged": {
    "*": "pnpm lint"
  }
}
