{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@logue/reverb",
  "version": "1.6.0",
  "description": "JavaScript Reverb effect class",
  "keywords": [
    "webaudio",
    "convolver",
    "effect",
    "reverb"
  ],
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "Logue",
    "email": "logue@hotmail.co.jp",
    "url": "https://logue.dev/"
  },
  "homepage": "https://github.com/logue/Reverb.js",
  "repository": {
    "type": "git",
    "url": "git@github.com:logue/Reverb.js.git"
  },
  "bugs": {
    "url": "https://github.com/logue/Reverb.js/issues"
  },
  "files": [
    "dist"
  ],
  "main": "dist/Reverb.umd.js",
  "module": "dist/Reverb.es.js",
  "browser": "dist/Reverb.umd.js",
  "types": "dist/Reverb.d.ts",
  "exports": {
    ".": {
      "import": "./dist/Reverb.es.js",
      "types": "./dist/Reverb.d.ts",
      "require": "./dist/Reverb.umd.js",
      "default": "./dist/Reverb.es.js"
    },
    "./umd": {
      "default": "./dist/Reverb.umd.js"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "packageManager": "pnpm@11.9.0",
  "sideEffects": false,
  "scripts": {
    "dev": "rslib --watch",
    "dev:docs": "rsbuild",
    "preview": "rsbuild preview",
    "lint": "run-s lint:*",
    "lint:check": "biome check --write",
    "lint:rslint": "rslint .",
    "lint:format": "prettier --write .",
    "build": "run-s build:lib build:dts",
    "build:lib": "rslib build",
    "build:dts": "dts-bundle-generator --project ./tsconfig.app.json --no-banner -o dist/Reverb.d.ts src/index.ts",
    "test": "rstest",
    "test:watch": "rstest --watch",
    "version": "auto-changelog -p && git add CHANGELOG.md",
    "prepare": "husky install"
  },
  "peerDependencies": {
    "@thi.ng/colored-noise": "^1",
    "@thi.ng/random": "^4",
    "@thi.ng/transducers": "^9.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@rsbuild/core": "^2.1.0",
    "@rslib/core": "^0.23.0",
    "@rslint/core": "^0.6.3",
    "@rstest/adapter-rslib": "^0.10.6",
    "@rstest/core": "^0.10.6",
    "@tsconfig/node-lts": "^24.0.0",
    "@types/node": "^26.0.1",
    "@types/three": "^0.185.0",
    "dts-bundle-generator": "^9.5.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.8.5",
    "three": "^0.185.0",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*": "pnpm lint:format"
  }
}
