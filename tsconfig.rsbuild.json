{
  "extends": "./tsconfig.rslib.json",
  "include": ["env.d.ts", "src/**/*", "src-docs/**/*"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.rsbuild.tsbuildinfo",
    "rootDir": ".",

    "types": ["@rsbuild/core/types", "node"],
    "useDefineForClassFields": true,

    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
