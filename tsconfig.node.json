{
  "extends": "@tsconfig/node-lts/tsconfig.json",
  "include": [
    "env.d.ts",
    "rsbuild.config.*",
    "rslib.config.*",
    "rslint.config.*",
    "package.json"
  ],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "resolveJsonModule": true,
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
